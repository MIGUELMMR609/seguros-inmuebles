# Base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:contraseña@host:5432/seguros_inmuebles

# JWT
JWT_SECRET=tu_secreto_jwt_muy_seguro_aqui

# Gmail SMTP para alertas
GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=tu_contraseña_de_aplicacion_gmail

# Email del administrador que recibirá las alertas
ADMIN_EMAIL=admin@tudominio.com

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development

# Cloudinary (almacenamiento de PDFs y fotos)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Anthropic (análisis IA de pólizas y contratos)
ANTHROPIC_API_KEY=tu_anthropic_api_key

# Usuario admin por defecto (solo se usa si no existe ningún admin en BD)
ADMIN_DEFAULT_EMAIL=admin@tudominio.com
ADMIN_DEFAULT_PASSWORD=cambia_esta_contraseña
